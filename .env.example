# ─── Database ────────────────────────────────────────────────────────────────
# Copy from Railway → Postgres service → Variables tab
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# ─── Auth ────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-here"

# GitHub OAuth App — create at github.com/settings/developers
# Callback URL: https://your-domain.com/api/auth/callback/github
AUTH_GITHUB_ID="your-github-oauth-client-id"
AUTH_GITHUB_SECRET="your-github-oauth-client-secret"

# ─── AI Providers ────────────────────────────────────────────────────────────
# At least one provider is required. DeepSeek is the default (fastest + cheapest).
# Multiple keys enable automatic fallback: DeepSeek → OpenAI → Anthropic

# DeepSeek — https://platform.deepseek.com
DEEPSEEK_API_KEY="sk-..."

# OpenAI — https://platform.openai.com/api-keys
# OPENAI_API_KEY="sk-..."

# Anthropic — https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY="sk-ant-..."

# ─── Redis ───────────────────────────────────────────────────────────────────
# Copy from Railway → Redis service → Variables tab
# Used for: BullMQ job queue, rate limiting
REDIS_URL="redis://default:PASSWORD@HOST:PORT"

# ─── App URL ─────────────────────────────────────────────────────────────────
# Must match your deployment URL (no trailing slash)
# Local: http://localhost:3000
# Production: https://your-app.up.railway.app
NEXTAUTH_URL="http://localhost:3000"
APP_URL="http://localhost:3000"
