# Database — copy from Railway → Postgres service → Variables tab
DATABASE_URL="postgresql://..."
DIRECT_URL="postgresql://..."

# Auth secret — generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-here"

# GitHub OAuth App — create at github.com/settings/developers
AUTH_GITHUB_ID="your-github-client-id"
AUTH_GITHUB_SECRET="your-github-client-secret"

# GitHub Personal Access Token — for posting PR comments (repo scope)
# Create at github.com/settings/tokens
GITHUB_TOKEN="ghp_..."

# AI Provider — pick one
ANTHROPIC_API_KEY="sk-ant-..."
# OPENAI_API_KEY="sk-..."

# Redis — from Railway Redis service
REDIS_URL="redis://..."

# App URL — localhost for dev, Railway URL for production
NEXTAUTH_URL="http://localhost:3000"
APP_URL="http://localhost:3000"
